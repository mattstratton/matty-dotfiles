[user]
	name = Matt Stratton
	email = matt.stratton@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIIPNBf32CVOD+EwvqOrbWd28JJ7OnY5HyKb7421mAYkw
[commit]
	gpgsign = true
[gpg]
    format = ssh

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
[credentialg]
	helper = osxkeychain
[core]
	excludesfile = /Users/mattstratton/.gitignore_global
[pull]
	rebase = false
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[url "git@github.com:"]
	insteadOf = https://github.com/
